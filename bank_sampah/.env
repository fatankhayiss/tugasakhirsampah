# PENTING: Untuk Gmail, gunakan 16-digit Google App Password, BUKAN password biasa akun Gmail Anda.

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=itrashy.app@gmail.com
